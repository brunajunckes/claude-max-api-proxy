# Port the proxy listens on
PORT=3456

# Directory containing your repos (mounted read-write into the container)
REPOS_DIR=/opt/repos

# Claude CLI config paths (defaults to ~/.claude and ~/.claude.json)
# CLAUDE_CONFIG_DIR=/home/youruser/.claude
# CLAUDE_CONFIG_FILE=/home/youruser/.claude.json

# Default extended-thinking budget applied when the client does not send one.
# Accepts an integer (tokens) or one of: minimal, low, medium, high.
# Use this when your client (e.g. OpenClaw) cannot pass thinking settings via the OpenAI API.
# DEFAULT_THINKING_BUDGET=high
